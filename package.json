    "demo:benchmark": "node --import tsx/esm scripts/benchmark.ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "@triton-one/yellowstone-grpc": "^5.0.7",
    "bs58": "^6.0.0",
    "express": "^4.21.2",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
