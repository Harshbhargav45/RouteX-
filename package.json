{
  "name": "routex",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx/esm src/index.ts",
    "start": "node --import tsx/esm src/index.ts",
    "typecheck": "tsc --noEmit",
    "demo:cluster": "node --import tsx/esm src/mock-cluster.ts",
